# Groq (default for this project). Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_key_here
# Optional: default is llama-3.1-8b-instant. Others: llama-3.3-70b-versatile, mixtral-8x7b-32768
# GROQ_MODEL=llama-3.1-8b-instant

# Gemini (optional, if you switch back)
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.0-flash
